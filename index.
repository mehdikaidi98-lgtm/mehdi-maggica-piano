<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Mehdi Piano XL - Version Longue</title>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: white; overflow: hidden; }
        
        /* PAGE DE GARDE */
        #welcome-screen {
            position: fixed; width: 100%; height: 100%; background: radial-gradient(circle, #1a1a2e, #0f0f1a);
            display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 100; transition: 0.8s;
        }
        .logo { font-size: 5rem; text-shadow: 0 0 20px #2ecc71; margin-bottom: 20px; animation: glow 2s infinite alternate; }
        .start-btn { 
            padding: 20px 40px; font-size: 1.5rem; background: #2ecc71; color: white; border: none; 
            border-radius: 50px; cursor: pointer; box-shadow: 0 0 20px rgba(46, 204, 113, 0.5); transition: 0.3s;
        }
        .start-btn:hover { transform: scale(1.1); background: #27ae60; }

        /* INTERFACE PIANO */
        #piano-interface { display: none; height: 100vh; flex-direction: row; align-items: center; justify-content: center; }
        
        .sidebar { width: 150px; height: 80%; background: rgba(255,255,255,0.05); border-right: 3px solid #2ecc71; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; border-radius: 0 20px 20px 0; }
        .piano-container { background: #333; padding: 20px; border-radius: 15px; border: 2px solid #2ecc71; }
        .piano { display: flex; }
        .key { cursor: pointer; transition: 0.1s; position: relative; }
        .white { width: 40px; height: 200px; background: white; border: 1px solid #ddd; border-radius: 0 0 5px 5px; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 10px; color: #333; font-weight: bold; }
        .black { width: 28px; height: 120px; background: #222; margin: 0 -14px; z-index: 2; border-radius: 0 0 3px 3px; }
        
        /* Animation quand l'IA joue ou quand on clique */
        .playing { background: #2ecc71 !important; color: white !important; transform: translateY(2px); }
        .white:active { background: #2ecc71; }

        @keyframes glow { from { text-shadow: 0 0 10px #2ecc71; } to { text-shadow: 0 0 30px #2ecc71, 0 0 40px #27ae60; } }
    </style>
</head>
<body>

    <div id="welcome-screen">
        <div class="logo">MEHDI PIANO</div>
        <p>Prêt pour la version longue de l'IA ?</p>
        <button class="start-btn" onclick="enterPiano()">ENTRER 🎹</button>
    </div>

    <div id="piano-interface">
        <div class="sidebar">
            <h3 style="color:#2ecc71; text-align: center;">AI MUSIC</h3>
            <button style="background:#f72585; color:white; border:none; padding:10px; border-radius:5px; cursor:pointer; font-weight: bold;" onclick="toggleIA()" id="iaBtn">MODE IA : OFF</button>
            <p style="font-size: 0.7rem; margin-top: 10px; text-align: center;">Active le mode IA et clique sur MI pour Élise !</p>
        </div>
        <div style="flex-grow:1; display:flex; flex-direction:column; align-items:center;">
            <h1 style="color:#2ecc71">Mehdi Piano XL</h1>
            <div class="piano-container">
                <div class="piano" id="keyboard"></div>
            </div>
        </div>
    </div>

    <script>
        let audioCtx;
        let isIA = false;
        const freqs = [261, 277, 293, 311, 329, 349, 370, 392, 415, 440, 466, 494, 523, 554, 587, 622, 659, 698, 740, 784, 831, 880, 932, 988];
        const names = ["DO", "", "RE", "", "MI", "FA", "", "SOL", "", "LA", "", "SI", "DO", "", "RE", "", "MI", "FA", "", "SOL", "", "LA", "", "SI"];

        function enterPiano() {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            document.getElementById('welcome-screen').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('welcome-screen').style.display = 'none';
                document.getElementById('piano-interface').style.display = 'flex';
                buildPiano();
            }, 800);
        }

        function buildPiano() {
            const kb = document.getElementById('keyboard');
            freqs.forEach((f, i) => {
                const key = document.createElement('div');
                key.className = `key ${names[i] ? 'white' : 'black'}`;
                key.id = "freq-" + f; // On donne un ID pour l'animer
                if(names[i]) key.innerHTML = `<span>${names[i]}</span>`;
                key.onclick = () => {
                    if(isIA && f === 329) playLongElise();
                    else playNote(f);
                };
                kb.appendChild(key);
            });
        }

        function playNote(f, duration = 0.5) {
            const o = audioCtx.createOscillator();
            const g = audioCtx.createGain();
            o.type = 'triangle'; o.frequency.value = f;
            g.gain.setValueAtTime(0.2, audioCtx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
            o.connect(g); g.connect(audioCtx.destination);
            o.start(); o.stop(audioCtx.currentTime + duration);
        }

        // VERSION LONGUE DE LA LETTRE À ÉLISE
        async function playLongElise() {
            // [Fréquence, Durée]
            const notes = [
                [659, 200], [622, 200], [659, 200], [622, 200], [659, 200], [494, 200], [587, 200], [523, 200], [440, 400],
                [261, 200], [330, 200], [440, 200], [494, 400], 
                [330, 200], [415, 200], [494, 200], [523, 400],
                [330, 200], [659, 200], [622, 200], [659, 200], [622, 200], [659, 200], [494, 200], [587, 200], [523, 200], [440, 400]
            ];

            for(let n of notes) {
                const keyElem = document.getElementById("freq-" + n[0]);
                if(keyElem) keyElem.classList.add('playing');
                
                playNote(n[0], n[1]/1000 + 0.2);
                await new Promise(r => setTimeout(r, n[1]));
                
                if(keyElem) keyElem.classList.remove('playing');
            }
        }

        function toggleIA() {
            isIA = !isIA;
            document.getElementById('iaBtn').innerText = isIA ? "MODE IA : ON ⭐" : "MODE IA : OFF";
            document.getElementById('iaBtn').style.background = isIA ? "#2ecc71" : "#f72585";
        }
    </script>
</body>
</html>
